---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Start | Julian Hilgemann"
    noHeader={true}
    noFooter={true}
    noAnalytics={true}
    fullWidth={true}
    noTopPadding={true}
>
    <!-- specialized style for this page to handle vertical centering perfectly -->
    <style is:global>
        /* Force main to behave as a flex container for vertical alignment on this page */
        main {
            display: flex !important;
            flex-direction: column;
        }
    </style>

    <!-- Background Blobs (Simplified Hero Effect) -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
        <div
            class="absolute top-0 right-0 w-[500px] h-[500px] translate-x-1/3 -translate-y-1/4"
        >
            <div
                class="w-full h-full bg-primary/10 rounded-full blur-[140px] animate-blob"
            >
            </div>
        </div>
        <div
            class="absolute bottom-0 left-0 w-[400px] h-[400px] -translate-x-1/3 translate-y-1/3"
        >
            <div
                class="w-full h-full bg-info/10 rounded-full blur-[120px] animate-blob animation-delay-2000"
            >
            </div>
        </div>
    </div>

    <div
        class="flex-1 w-full flex flex-col items-center justify-center p-4 z-10 my-auto"
    >
        <div class="text-center mb-12 w-full max-w-4xl">
            <h1
                class="text-4xl sm:text-6xl font-black mb-6 tracking-tight text-white drop-shadow-sm"
            >
                Welcome
            </h1>
            <div
                class="flex items-center justify-center gap-2 text-text-secondary"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="opacity-80"
                >
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"
                    ></path>
                    <path d="M2 12h20"></path>
                </svg>
                <span
                    class="text-sm sm:text-base font-medium uppercase tracking-wider"
                    >Select a Language</span
                >
            </div>
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-2xl px-4"
        >
            <!-- English -->
            <a href="/hub" class="hub-card glass group">
                <div class="text-center">
                    <span class="hub-text text-xl sm:text-2xl tracking-[0.2em]"
                        >ENGLISH</span
                    >
                </div>
            </a>

            <!-- German -->
            <a href="/de/hub" class="hub-card glass group">
                <div class="text-center">
                    <span class="hub-text text-xl sm:text-2xl tracking-[0.2em]"
                        >DEUTSCH</span
                    >
                </div>
            </a>
        </div>
    </div>
</Layout>

<style>
    @keyframes blob {
        0% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(30px, -50px) scale(1.1);
        }
        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }
        100% {
            transform: translate(0, 0) scale(1);
        }
    }
    .animate-blob {
        animation: blob 7s infinite ease-in-out;
    }
    .animation-delay-2000 {
        animation-delay: 2s;
    }

    /* Card Styling */
    .hub-card {
        @apply flex flex-col items-center justify-center p-6 sm:p-10 rounded-2xl sm:rounded-3xl border border-white/10 transition-all duration-500 relative overflow-hidden;
        min-height: 120px;
    }

    @media (min-width: 640px) {
        .hub-card {
            min-height: 180px;
        }
    }

    /* Hover States (Only on devices that support hover) */
    @media (hover: hover) {
        /* Hover State: Glow and Border */
        .hub-card:hover {
            @apply border-primary/60 bg-white/5;
            box-shadow: 0 0 30px rgba(245, 158, 11, 0.2);
            transform: translateY(-4px);
        }

        /* Text Hover */
        .hub-card:hover .hub-text {
            @apply text-primary;
            text-shadow: 0 0 10px rgba(245, 158, 11, 0.3);
        }
    }

    /* Text Styling */
    .hub-text {
        @apply font-bold text-text-primary transition-colors duration-300 block;
    }
</style>
