---
import Layout from "../../layouts/LayoutDE.astro";
import Hero from "../../components/de/Hero.astro";
import CredibilityBar from "../../components/de/CredibilityBar.astro";
import Projects from "../../components/de/Projects.astro";
import SecondaryCTA from "../../components/de/SecondaryCTA.astro";
---

<Layout
    title="Julian Hilgemann | Power BI Decision Dashboards & BI Systeme"
    description="Ich baue produktive Power BI-Dashboards und Entscheidungsschnittstellen – vertrauenswürdige Metriken, saubere Modelle und Berichte, die täglich von Führungskräften und Operations genutzt werden."
    fullWidth={true}
    noTopPadding={true}
>
    <!-- Hero Section -->
    <Hero />

    <!-- Credibility Bar -->
    <CredibilityBar />

    <!-- Projects Section -->
    <div class="py-12 max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold tracking-tight mb-4 text-center">
            Aktuelle Projekte
        </h2>
        <p class="text-text-secondary text-center max-w-2xl mx-auto mb-12">
            Eine Auswahl meiner aktuellen Open-Source-Arbeit und öffentlichen
            Projektbeiträge auf GitHub.
        </p>
    </div>
    <div class="-mt-12">
        <Projects />
    </div>

    <!-- Secondary CTA -->
    <SecondaryCTA />
</Layout>
