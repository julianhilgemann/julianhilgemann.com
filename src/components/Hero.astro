<section
    id="hero"
    class="min-h-0 md:min-h-[100svh] py-28 md:py-0 flex flex-col justify-center relative isolate overflow-hidden"
>
    <!-- ========================================== -->
    <!-- LAYER 1: Interactive Blobs (Deepest)       -->
    <!-- ========================================== -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none -z-40">
        <!-- Blob 1 (Top Right) -->
        <div class="hero-blob-wrapper absolute top-0 right-0 w-[500px] h-[500px] transition-transform duration-[2000ms] ease-out md:will-change-transform translate-x-1/3 -translate-y-1/4" data-speed="0.05">
            <div class="w-full h-full bg-primary/20 rounded-full blur-[60px] md:blur-[140px] animate-blob"></div>
        </div>

        <!-- Blob 2 (Bottom Left) -->
        <div class="hero-blob-wrapper absolute bottom-0 left-0 w-[400px] h-[400px] transition-transform duration-[2000ms] ease-out md:will-change-transform -translate-x-1/3 translate-y-1/3" data-speed="0.08">
            <div class="w-full h-full bg-info/20 rounded-full blur-[50px] md:blur-[120px] animate-blob animation-delay-2000"></div>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- LAYER 2: Canvas Particles (-z-30)          -->
    <!-- ========================================== -->
    <canvas id="particle-canvas" class="absolute inset-0 w-full h-full pointer-events-none -z-30"></canvas>

    <!-- ========================================== -->
    <!-- LAYER 3: Global Glass Layer (-z-20)        -->
    <!-- Blurs the particles AND the blobs          -->
    <!-- ========================================== -->
    <div class="absolute inset-0 bg-background/20 backdrop-blur-[5px] pointer-events-none -z-20"></div>

    <!-- ========================================== -->
    <!-- LAYER 4: Content & Buttons (Top, z-10)     -->
    <!-- ========================================== -->
    <div
        class="w-full max-w-[1200px] mx-auto px-8 sm:px-12 lg:px-16 relative z-10 pointer-events-none"
    >
        <div class="max-w-3xl">
            <h1
                class="text-5xl md:text-7xl font-bold tracking-tight mb-6 md:mb-8 leading-[1.1]"
            >
                Turn Data Into <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-yellow-300"
                    >Decisions</span
                > That Drive Revenue
            </h1>

            <p
                class="text-xl md:text-2xl text-text-primary drop-shadow-md mb-8 md:mb-10 leading-relaxed max-w-2xl"
            >
                <strong
                    >I design and build decision-ready Power BI dashboards that
                    teams can use immediately.</strong
                >
                <br />
                <span class="text-lg md:text-xl text-text-secondary mt-2 block"
                    >From messy data to clear KPIs, trusted numbers, and
                    confident decisions.</span
                >
            </p>

            <div class="flex flex-col sm:flex-row gap-4 pointer-events-auto">
                <a
                    href="/services"
                    class="glass hover:bg-white/10 text-white font-medium py-3 px-6 rounded-full transition-all border !border-primary text-center"
                >
                    Services & Packages
                </a>
                <a
                    href="/about"
                    class="glass hover:bg-white/10 text-white font-medium py-3 px-6 rounded-full transition-all border border-white/10 text-center"
                >
                    About me
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes blob {
        0% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(30px, -50px) scale(1.1);
        }
        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }
        100% {
            transform: translate(0, 0) scale(1);
        }
    }
    .animate-blob {
        animation: blob 7s infinite ease-in-out;
    }
    .animation-delay-2000 {
        animation-delay: 2s;
    }
</style>

<script>
    // ==========================================
    // 1. CUSTOM CANVAS PARTICLES LOGIC
    // ==========================================
    const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
    const ctx = canvas?.getContext('2d');
    const heroSection = document.getElementById("hero");
    
    if (canvas && ctx && heroSection) {
        let points: Point[] = [];
        const numPoints = window.innerWidth < 768 ? 60 : 130; 
        const maxDist = 180;

        const resizeCanvas = () => {
            canvas.width = heroSection.offsetWidth;
            canvas.height = heroSection.offsetHeight;
        };
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class Point {
            x: number;
            y: number;
            vx: number;
            vy: number;
            radius: number;

            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.vx = (Math.random() - 0.5) * 2;
                this.vy = (Math.random() - 0.5) * 2;
                
                // Randomize the radius between 1px and 5px
                this.radius = Math.random() * 4 + 1; 
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;

                if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
                if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
            }
        }

        for (let i = 0; i < numPoints; i++) points.push(new Point());

        const draw = () => {
            if (!ctx) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            for (let i = 0; i < points.length; i++) {
                let p1 = points[i];
                p1.update();

                // Draw Dots (Contour / Outline Rings only)
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.4)'; // Ring color and opacity
                ctx.lineWidth = 1.5; // Thickness of the ring
                ctx.beginPath();
                ctx.arc(p1.x, p1.y, p1.radius, 0, Math.PI * 2);
                ctx.stroke(); // Used stroke() instead of fill() to make them hollow

                // Check distances to draw lines
                for (let j = i + 1; j < points.length; j++) {
                    let p2 = points[j];
                    let dx = p1.x - p2.x;
                    let dy = p1.y - p2.y;
                    let dist = Math.sqrt(dx * dx + dy * dy);

                    if (dist < maxDist) {
                        ctx.strokeStyle = `rgba(255, 255, 255, ${(1 - dist/maxDist) * 0.5})`;
                        ctx.lineWidth = 1;
                        ctx.beginPath();
                        ctx.moveTo(p1.x, p1.y);
                        ctx.lineTo(p2.x, p2.y);
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(draw);
        };
        draw();
    }

    // ==========================================
    // 2. INTERACTIVE BLOBS LOGIC
    // ==========================================
    const wrappers = document.querySelectorAll(".hero-blob-wrapper");

    if (heroSection) {
        heroSection.addEventListener("mousemove", (e) => {
            const rect = heroSection.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;

            wrappers.forEach((wrapper) => {
                const speed = parseFloat(wrapper.getAttribute("data-speed") || "0.05");
                const moveX = (x - centerX) * speed * 2;
                const moveY = (y - centerY) * speed * 2;
                (wrapper as HTMLElement).style.transform = `translate(${moveX}px, ${moveY}px)`;
            });
        });

        heroSection.addEventListener("mouseleave", () => {
            wrappers.forEach((wrapper) => {
                (wrapper as HTMLElement).style.transform = `translate(0, 0)`;
            });
        });
    }
</script>
