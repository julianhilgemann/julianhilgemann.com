---
const { lang = "en" } = Astro.props;

interface NavItem {
    name: string;
    href: string;
}

const navItemsEN: NavItem[] = [
    { name: "Home", href: "/" },
    { name: "About", href: "/about" },
    { name: "Services", href: "/services" },
];

const navItemsDE: NavItem[] = [
    { name: "Home", href: "/de" },
    { name: "Über mich", href: "/de/about" },
    { name: "Leistungen", href: "/de/services" },
];

const navItems = lang === "de" ? navItemsDE : navItemsEN;
const contactText = lang === "de" ? "Kontakt" : "Contact";

const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
    // Exact match for home pages, prefix match for others
    if (href === "/" || href === "/de") {
        return currentPath === href || currentPath === href + "/";
    }
    return currentPath.startsWith(href);
};
---

<header class="fixed top-0 left-0 right-0 z-50 pointer-events-none">
    <!-- Main Navbar Container -->
    <div
        class="glass mx-auto mt-4 w-[calc(100%-2rem)] max-w-[1200px] rounded-[32px] px-4 py-3 md:px-6 md:py-3 flex items-center justify-between pointer-events-auto shadow-sm relative z-50 transition-colors duration-300"
        id="navbar-container"
    >
        <!-- Logo Area -->
        <div class="flex flex-1 justify-start z-50">
            <a
                href={lang === "de" ? "/de" : "/"}
                class="font-bold tracking-tight hover:text-primary transition-colors duration-300 ease-in-out shrink-0"
            >
                <span class="md:hidden text-lg">JH</span>
                <span class="hidden md:inline text-lg">Julian Hilgemann</span>
            </a>
        </div>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-8 shrink-0 relative z-50">
            {
                navItems.map((item, index) => (
                    <>
                        <a
                            href={item.href}
                            class:list={[
                                "text-sm font-medium transition-colors duration-300 ease-in-out",
                                isActive(item.href)
                                    ? "text-primary"
                                    : "text-white hover:text-primary",
                            ]}
                        >
                            {item.name}
                        </a>
                        {index < navItems.length - 1 && (
                            <span
                                class="w-px h-3 bg-white/10 block"
                                aria-hidden="true"
                            />
                        )}
                    </>
                ))
            }
        </nav>

        <!-- Right Side: Lang & Desktop Contact & Mobile Toggle -->
        <div class="flex flex-1 justify-end items-center gap-4 z-50">
            <!-- Language Switcher -->
            <div class="relative group hidden md:block">
                <button
                    class="text-white hover:text-primary transition-colors duration-300 p-2 flex items-center justify-center shrink-0"
                    aria-label="Switch Language"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="12" cy="12" r="10"></circle>
                        <path
                            d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"
                        ></path>
                        <path d="M2 12h20"></path>
                    </svg>
                </button>
                <!-- Dropdown -->
                <div
                    class="absolute right-0 top-full mt-2 w-32 glass !bg-[#0B1221] border border-white/10 rounded-xl overflow-hidden invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-300 transform origin-top-right flex flex-col"
                >
                    {
                        lang === "en" ? (
                            <>
                                <span class="px-4 py-3 text-sm text-primary font-bold bg-white/5 cursor-default">
                                    ENG
                                </span>
                                <a
                                    href="/de"
                                    class="px-4 py-3 text-sm text-white hover:text-primary hover:bg-white/10 transition-colors"
                                >
                                    GER
                                </a>
                            </>
                        ) : (
                            <>
                                <a
                                    href="/"
                                    class="px-4 py-3 text-sm text-white hover:text-primary hover:bg-white/10 transition-colors"
                                >
                                    ENG
                                </a>
                                <span class="px-4 py-3 text-sm text-primary font-bold bg-white/5 cursor-default">
                                    GER
                                </span>
                            </>
                        )
                    }
                </div>
            </div>

            <!-- Desktop Contact CTA -->
            <a
                href="#"
                class="hidden md:inline-flex glass hover:bg-white/10 text-white text-sm font-medium py-2 px-4 rounded-full transition-all duration-300 ease-in-out border !border-primary text-center whitespace-nowrap js-open-contact"
                data-location="header-cta"
            >
                {contactText}
            </a>

            <!-- Mobile Menu Toggle Button -->
            <button
                id="mobile-menu-toggle"
                class="md:hidden flex items-center justify-center w-10 h-10 rounded-full border border-white/10 hover:border-white/20 transition-colors relative"
                aria-label="Toggle Menu"
            >
                <div
                    class="relative w-4 h-4 display-flex items-center justify-center"
                >
                    <!-- Horizontal line -->
                    <span
                        class="absolute w-4 h-[1.5px] bg-white rounded-full transition-transform duration-300 ease-out"
                        id="line-h"></span>
                    <!-- Vertical line -->
                    <span
                        class="absolute h-4 w-[1.5px] bg-white rounded-full transition-transform duration-300 ease-out"
                        id="line-v"></span>
                </div>
            </button>
        </div>
    </div>

    <!-- Mobile Dropdown Menu -->
    <div
        id="mobile-menu"
        class="fixed inset-x-0 top-[4.5rem] p-4 pointer-events-none z-40"
    >
        <div
            class="glass flex flex-col items-center bg-[#0d1527] w-full rounded-3xl overflow-hidden transition-all duration-[400ms] ease-[cubic-bezier(0.25,1,0.5,1)] origin-top opacity-0 scale-y-0"
            id="mobile-menu-inner"
        >
            <nav
                class="flex flex-col w-full py-6 px-4 gap-6 pointer-events-auto max-w-sm mx-auto"
            >
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            class:list={[
                                "text-2xl font-medium text-center transition-colors duration-300 nav-link-mobile",
                                isActive(item.href)
                                    ? "text-primary"
                                    : "text-white hover:text-primary",
                            ]}
                        >
                            {item.name}
                        </a>
                    ))
                }

                <hr class="border-white/10 w-full my-2" />

                <div class="flex flex-col items-center gap-4 w-full">
                    <a
                        href="#"
                        class="glass hover:bg-white/10 text-white text-lg font-medium py-3 px-8 rounded-full transition-all duration-300 border !border-primary text-center w-full js-open-contact nav-link-mobile"
                        data-location="mobile-menu-cta"
                    >
                        {contactText}
                    </a>

                    <div
                        class="flex gap-4 items-center justify-center w-full mt-2"
                    >
                        <a
                            href={lang === "en" ? "#" : "/"}
                            class:list={[
                                "text-sm font-medium",
                                lang === "en"
                                    ? "text-primary"
                                    : "text-white/60 hover:text-white",
                            ]}>ENG</a
                        >
                        <span class="w-px h-3 bg-white/20"></span>
                        <a
                            href={lang === "de" ? "#" : "/de"}
                            class:list={[
                                "text-sm font-medium",
                                lang === "de"
                                    ? "text-primary"
                                    : "text-white/60 hover:text-white",
                            ]}>GER</a
                        >
                    </div>
                </div>
            </nav>
        </div>
    </div>
</header>

<script>
    const setupMobileMenu = () => {
        const toggle = document.getElementById("mobile-menu-toggle");
        const menu = document.getElementById("mobile-menu");
        const menuInner = document.getElementById("mobile-menu-inner");
        const lineH = document.getElementById("line-h");
        const lineV = document.getElementById("line-v");
        const navbarContainer = document.getElementById("navbar-container");
        const body = document.body;

        if (
            !toggle ||
            !menu ||
            !menuInner ||
            !lineH ||
            !lineV ||
            !navbarContainer
        )
            return;

        let isOpen = false;

        const closeMenu = () => {
            if (!isOpen) return;
            isOpen = false;

            // Icon animation to +
            lineH.style.transform = "rotate(0deg)";
            lineV.style.transform = "rotate(0deg)";

            // Menu animation out
            menuInner.classList.remove("opacity-100", "scale-y-100");
            menuInner.classList.add("opacity-0", "scale-y-0");

            // Remove scroll lock
            body.style.overflow = "";

            // Make menu unclickable after animation
            setTimeout(() => {
                if (!isOpen) menu.classList.add("pointer-events-none");
            }, 300);
        };

        const openMenu = () => {
            if (isOpen) return;
            isOpen = true;

            // Icon animation to X
            lineH.style.transform = "rotate(45deg)";
            lineV.style.transform = "rotate(45deg)";

            // Menu animation in
            menu.classList.remove("pointer-events-none");
            // small delay to ensure display block is applied before animating
            requestAnimationFrame(() => {
                menuInner.classList.remove("opacity-0", "scale-y-0");
                menuInner.classList.add("opacity-100", "scale-y-100");
            });

            // Add scroll lock
            body.style.overflow = "hidden";
        };

        const toggleMenu = (e: Event) => {
            e.stopPropagation();
            if (isOpen) {
                closeMenu();
            } else {
                openMenu();
            }
        };

        toggle.addEventListener("click", toggleMenu);

        // Close menu on click outside
        document.addEventListener("click", (e) => {
            if (
                isOpen &&
                !menuInner.contains(e.target as Node) &&
                !toggle.contains(e.target as Node)
            ) {
                closeMenu();
            }
        });

        // Handle escape key
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && isOpen) {
                closeMenu();
            }
        });

        // Close menu when clicking a link
        const navLinks = document.querySelectorAll(".nav-link-mobile");
        navLinks.forEach((link) => {
            link.addEventListener("click", () => {
                // If it's a contact button, the modal script will handle the opening, we just need to close the menu
                closeMenu();
            });
        });
    };

    // Run on load
    setupMobileMenu();
    // Run on astro page swap
    document.addEventListener("astro:page-load", setupMobileMenu);
</script>
